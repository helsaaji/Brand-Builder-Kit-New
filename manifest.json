{
  "id": "/",
  "name": "Brand Builder Kit",
  "short_name": "BrandKit",
  "description": "Aplikasi PWA responsif untuk demonstrasi template dasar Progressive Web App dengan dukungan offline dan installable.",
  "start_url": "./index.html",
  "scope": "./",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "minimal-ui", "browser"],
  "background_color": "#0A0A1A",
  "theme_color": "#7C5CFC",
  "orientation": "portrait",
  "lang": "id",
  "dir": "ltr",
  "categories": ["productivity", "utilities", "design"],
  "iarc_rating_id": "e84b072d-71b3-4d3e-86ae-31a8ce4e53b7",
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "webapp",
      "url": "https://helsaaji.github.io/Brand-Builder-Kit-New/manifest.json"
    }
  ],
  "icons": [
    {
      "src": "./icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "./icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "./icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "./icons/screenshot1.png",
      "sizes": "1442x3090",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Brand Builder Kit — Tampilan Mobile"
    },
    {
      "src": "./icons/screenshot2.png",
      "sizes": "1442x3090",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Brand Builder Kit — Tampilan Mobile 2"
    },
    {
      "src": "./icons/screenshot-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Brand Builder Kit — Tampilan Desktop"
    }
  ],
  "shortcuts": [
    {
      "name": "Buka Beranda",
      "short_name": "Home",
      "description": "Buka halaman utama Brand Builder Kit",
      "url": "./index.html",
      "icons": [
        {
          "src": "./icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "share_target": {
    "action": "./index.html",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+brandkit",
      "url": "./index.html?url=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "./index.html",
      "accept": {
        "image/png": [".png"],
        "image/jpeg": [".jpg", ".jpeg"],
        "image/svg+xml": [".svg"],
        "application/json": [".json"]
      }
    }
  ],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": "navigate-existing"
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "note_taking": {
    "new_note_url": "./index.html"
  },
  "scope_extensions": [
    {
      "origin": "https://helsaaji.github.io"
    }
  ],
  "widgets": [
    {
      "name": "Brand Builder Widget",
      "tag": "brand-builder-widget",
      "description": "Widget Brand Builder Kit",
      "ms_ac_template": "./widget-template.json",
      "data": "./widget-data.json",
      "screenshots": [
        {
          "src": "./icons/screenshot1.png",
          "sizes": "1442x3090",
          "label": "Widget preview"
        }
      ],
      "icons": [
        {
          "src": "./icons/icon-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ],
      "auth": false,
      "update": 86400
    }
  ]
}